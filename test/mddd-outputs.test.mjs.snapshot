exports[`02 – Sequence (02-sequence-api.js) > snapshot completo 1`] = `
"sequenceDiagram\\n    participant Client\\n    participant Gateway\\n    participant AuthMiddleware\\n    participant Cache\\n    participant Server\\n    participant Database\\n    participant Notification\\n    participant AuditLog\\n    participant Error\\n    Client->>Gateway: HTTP Request + JWT\\n    Client->>AuthMiddleware: Token expired (401)\\n    Client->>Error: Error occurs\\n    Gateway->>AuthMiddleware: Validate token\\n    Gateway->>Client: JSON Response\\n    AuthMiddleware->>Server: Forward request\\n    Cache->>Server: Cache hit/miss\\n    Server->>Cache: Check cache\\n    Server->>Database: SQL Query (with JOIN)\\n    Server->>Cache: Store in cache\\n    Server->>Gateway: User response\\n    Server->>AuditLog: Record action\\n    Server->>Notification: Send welcome email\\n    Database->>Server: User data\\n    Notification->>Client: Push notification\\n"
`;

exports[`03 – Class (03-class-diagram-oop.py) > snapshot completo 1`] = `
"classDiagram\\n    class Address {\\n    +init()\\n    +Get Full Address()\\n    }\\n    class User {\\n    +init()\\n    +Add Address()\\n    +Get Default Address()\\n    +Place Order()\\n    }\\n    class Customer {\\n    +init()\\n    +Add To Wishlist()\\n    +Calculate Discount()\\n    }\\n    class Admin {\\n    +init()\\n    +Manage Product()\\n    }\\n    class Product {\\n    +init()\\n    +Update Stock()\\n    +Get Avg Rating()\\n    }\\n    class Category {\\n    +init()\\n    +Add Product()\\n    +Add Subcategory()\\n    }\\n    class ShoppingCart {\\n    +init()\\n    +Add Item()\\n    +Get Subtotal()\\n    }\\n    class CartItem {\\n    +init()\\n    }\\n    class Order {\\n    +init()\\n    +Calculate Total()\\n    +Confirm()\\n    }\\n    class Payment {\\n    +init()\\n    +Process()\\n    +Refund()\\n    }\\n    class Shipping {\\n    +init()\\n    +Update Tracking()\\n    +Mark Delivered()\\n    }\\n    class Review {\\n    +init()\\n    }\\n    User --> Order\\n    Admin --> Product\\n"
`;

exports[`04 – State (04-state-machine-login.js) > snapshot completo 1`] = `
"stateDiagram-v2\\n    state LoggedOut {\\n        DisplayLoginForm: Display Login Form\\n        DisplayRegisterLink: Display Register Link\\n    }\\n    state LoggingIn {\\n        ValidateCredentials: Validate Credentials\\n        IncrementFailedAttempts: Increment Failed Attempts\\n    }\\n    state TwoFactorAuth {\\n        OnEnter: On Enter\\n        SendCode: Send Code\\n        VerifyCode: Verify Code\\n    }\\n    state LoggedIn {\\n        OnEnter: On Enter\\n        StartTokenRefreshTimer: Start Token Refresh Timer\\n        Logout: Logout\\n    }\\n    state PasswordReset {\\n        RequestReset: Request Reset\\n        ConfirmReset: Confirm Reset\\n    }\\n    state AccountLocked {\\n        OnEnter: On Enter\\n        CheckUnlock: Check Unlock\\n        RequestUnlock: Request Unlock\\n    }\\n    state SessionExpired {\\n        OnEnter: On Enter\\n        RedirectToLogin: Redirect To Login\\n    }\\n    LoggedOut --> LoggingIn: User submits credentials\\n    LoggedOut --> PasswordReset: Forgot password clicked\\n    LoggingIn --> LoggedIn: Login successful + 2FA verified\\n    LoggingIn --> TwoFactorAuth: 2FA required\\n    LoggingIn --> AccountLocked: Too many failed attempts\\n    TwoFactorAuth --> LoggedIn: 2FA code verified\\n    TwoFactorAuth --> AccountLocked: Too many failed 2FA attempts\\n    LoggedIn --> SessionExpired: Token expired\\n    LoggedIn --> LoggedOut: User logged out\\n    PasswordReset --> LoggedOut: Password reset complete\\n    AccountLocked --> LoggedOut: Lock duration expired\\n    SessionExpired --> LoggedOut: User redirected\\n"
`;

exports[`05 – ER (05-er-database.sql) > snapshot completo 1`] = `
"erDiagram\\n    User {\\n        string id\\n        string name\\n        string email\\n        string phone\\n        string password_hash\\n        string avatar_url\\n        string two_factor_enabled\\n        string two_factor_secret\\n        string email_verified_at\\n        string locked_until\\n        string failed_attempts\\n        string loyalty_tier\\n        string loyalty_points\\n        string role\\n        string created_at\\n        string updated_at\\n        string deleted_at\\n    }\\n    Address {\\n        string id\\n        string user_id\\n        string label\\n        string street\\n        string number\\n        string complement\\n        string neighborhood\\n        string city\\n        string state\\n        string country\\n        string zip_code\\n        string is_default\\n        string created_at\\n    }\\n    Category {\\n        string id\\n        string name\\n        string slug\\n        string description\\n        string image_url\\n        string parent_id\\n        string sort_order\\n        string is_active\\n        string created_at\\n    }\\n    Product {\\n        string id\\n        string name\\n        string slug\\n        string description\\n        string short_description\\n        string price\\n        string compare_at_price\\n        string cost_price\\n        string sku\\n        string barcode\\n        string weight_kg\\n        string stock_quantity\\n        string min_stock_threshold\\n        string is_active\\n        string is_digital\\n        string created_at\\n        string updated_at\\n        string FULLTEXT\\n    }\\n    ProductCategory {\\n        string product_id\\n        string category_id\\n    }\\n    ProductImage {\\n        string id\\n        string product_id\\n        string url\\n        string alt_text\\n        string sort_order\\n        string is_primary\\n    }\\n    Order {\\n        string id\\n        string user_id\\n        string order_number\\n        string status\\n        string subtotal\\n        string discount_amount\\n        string shipping_cost\\n        string tax_amount\\n        string total\\n        string coupon_code\\n        string notes\\n        string shipping_address_id\\n        string billing_address_id\\n        string created_at\\n        string updated_at\\n    }\\n    OrderItem {\\n        string id\\n        string order_id\\n        string product_id\\n        string product_name\\n        string product_sku\\n        string unit_price\\n        string quantity\\n        string total_price\\n    }\\n    Payment {\\n        string id\\n        string order_id\\n        string method\\n        string status\\n        string amount\\n        string installments\\n        string gateway_transaction_id\\n        string gateway_response\\n        string paid_at\\n        string refunded_at\\n        string created_at\\n    }\\n    Shipping {\\n        string id\\n        string order_id\\n        string carrier\\n        string service_level\\n        string tracking_code\\n        string status\\n        string estimated_delivery\\n        string delivered_at\\n        string cost\\n        string created_at\\n        string updated_at\\n    }\\n    Review {\\n        string id\\n        string user_id\\n        string product_id\\n        string order_id\\n        string rating\\n        string title\\n        string comment\\n        string is_verified_purchase\\n        string is_approved\\n        string helpful_count\\n        string created_at\\n    }\\n    Session {\\n        string id\\n        string user_id\\n        string ip_address\\n        string user_agent\\n        string refresh_token\\n        string payload\\n        string last_activity\\n        string expires_at\\n        string created_at\\n    }\\n    AuditLog {\\n        string id\\n        string user_id\\n        string action\\n        string entity_type\\n        string entity_id\\n        string old_values\\n        string new_values\\n        string ip_address\\n        string user_agent\\n        string created_at\\n    }\\n    Coupon {\\n        string id\\n        string code\\n        string description\\n        string discount_type\\n        string discount_value\\n        string min_order_amount\\n        string max_uses\\n        string used_count\\n        string starts_at\\n        string expires_at\\n        string is_active\\n        string created_at\\n    }\\n    Cart {\\n        string id\\n        string user_id\\n        string session_token\\n        string created_at\\n        string updated_at\\n    }\\n    CartItem {\\n        string id\\n        string cart_id\\n        string product_id\\n        string quantity\\n        string added_at\\n    }\\n    Wishlist {\\n        string user_id\\n        string product_id\\n        string added_at\\n    }\\n    User ||--o{ Address : has many\\n    User ||--o{ Order : places\\n    User ||--o{ Review : writes\\n    User ||--o{ Session : has\\n    User ||--o{ Cart : has one\\n    User ||--o{ Wishlist : has many\\n    User ||--o{ AuditLog : generates\\n    Category ||--o{ Category : parent/child\\n    Category ||--o{ ProductCategory : belongs to\\n    Product ||--o{ ProductCategory : belongs to\\n    Product ||--o{ ProductImage : has many\\n    Product ||--o{ Review : has many\\n    Product ||--o{ CartItem : included in\\n    Product ||--o{ Wishlist : saved in\\n    Order ||--o{ OrderItem : contains\\n    Order ||--o{ Address : billing\\n    Order ||--o{ Address : shipping\\n    Order ||--o{ Payment : paid by\\n    Order ||--o{ Shipping : delivered via\\n    Order ||--o{ Review : reviewed in\\n    Order ||--o{ Coupon : applied\\n    OrderItem ||--o{ Product : references\\n    Cart ||--o{ CartItem : contains\\n    CartItem ||--o{ Product : references\\n"
`;
