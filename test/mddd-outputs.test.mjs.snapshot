"erDiagram\\n    User {\\n        string id\\n        string name\\n        string email\\n    }\\n    Order {\\n        string id\\n        string user_id\\n        string total\\n        string created_at\\n    }\\n    Product {\\n        string id\\n        string name\\n        string price\\n        string stock\\n    }\\n    OrderItem {\\n        string id\\n        string order_id\\n        string product_id\\n        string quantity\\n    }\\n    User ||--o{ Order : places\\n    Order ||--o{ OrderItem : contains\\n    OrderItem ||--o{ Product : references\\n"
