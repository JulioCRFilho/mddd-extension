exports[`02 – Sequence (02-sequence-api.js) > snapshot completo 1`] = `
"sequenceDiagram\\n    participant Client\\n    participant Server\\n    participant Database\\n    participant Error\\n    Client->>Server: HTTP Request\\n    Client->>Error: Error occurs\\n    Server->>Database: SQL Query\\n    Server->>Client: JSON Response\\n    Database->>Server: User data\\n"
`;

exports[`03 – Class (03-class-diagram-oop.py) > snapshot completo 1`] = `
