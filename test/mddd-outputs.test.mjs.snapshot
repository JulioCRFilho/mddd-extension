`;

exports[`04 – State (04-state-machine-login.js) > snapshot completo 1`] = `
"stateDiagram-v2\\n    state LoggedOut {\\n        DisplayForm: Display Form\\n    }\\n    state LoggedIn {\\n        LoadUserData: Load User Data\\n        RenderDashboard: Render Dashboard\\n    }\\n    state SessionExpired {\\n        ClearSession: Clear Session\\n        RedirectToLogin: Redirect To Login\\n    }\\n    LoggedOut --> LoggedIn: Login success\\n    LoggedIn --> SessionExpired: Token expired\\n    SessionExpired --> LoggedOut: Clear state\\n"
`;

